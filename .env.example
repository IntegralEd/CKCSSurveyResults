# Airtable Personal Access Token (starts with "pat")
AIRTABLE_API_KEY=your_airtable_pat_here

# Airtable Base ID (starts with "app")
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Table names — change only if your Airtable tables use different names
AIRTABLE_TABLE_RESPONDENTS=Survey_Respondents
AIRTABLE_TABLE_ITEMS=Survey_Items
AIRTABLE_TABLE_COMMENTS=Survey_Item_Comments
